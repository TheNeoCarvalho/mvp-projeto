{
  "name": "grupo-tereza-gastronomia",
  "version": "0.1.0",
  "description": "Backend RESTful para gestão de filiais e fornecedores - Grupo Tereza Gastronomia",
  "main": "src/server.ts",
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts",
    "start": "tsx src/server.ts",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:generate": "npx prisma generate",
    "prisma:studio": "npx prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "envalid": "^8.1.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "pg": "^8.15.0",
    "pino": "^10.3.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
